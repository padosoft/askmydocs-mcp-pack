# =============================================================================
# padosoft/askmydocs-mcp-pack — env snippet
# =============================================================================
# Copy these lines into the consumer host's .env / .env.example. All knobs
# default to OFF; opt in deliberately.

# Master kill-switch. Set to true once you have wired McpHostBridgeContract.
MCP_PACK_TOOL_CALLING_ENABLED=false

# Hard cap on tool-calling loops per chat turn. 3 is the sweet spot for
# grounded QA; raise to 5+ only for agentic flows.
MCP_PACK_TOOL_CALLING_MAX_ITERATIONS=3

# OpenAI-style tool_choice hint passed to the host bridge. Valid values:
# 'auto' | 'required' | 'none' | {"type":"function","function":{"name":"..."}}
MCP_PACK_TOOL_CHOICE=auto

# How long to cache `initialize` + `tools/list` per (tenant, server).
# Set to 0 to disable caching entirely (useful in tests).
MCP_PACK_HANDSHAKE_TTL=300

# FQCN of the audit model. Override to subclass.
# MCP_PACK_AUDIT_MODEL="Padosoft\\AskMyDocsMcpPack\\Models\\McpToolCallAudit"
